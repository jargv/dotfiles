# C++ snippets. Dynamic/choice ones (for, l) stay in lua_snippets/cpp.lua.
snippet if if block
	if (${1:true}) {
	  ${0}
	}
snippet while while loop
	while (${1}) {
	  ${0}
	}
snippet fn lambda bound to auto
	auto ${1} = [${3}](${2}){
	  ${0}
	};
snippet lm bare lambda
	[${2}](${1}){
	  ${0}
	}
snippet log LOG line
	LOG("${1}");
snippet req REQUIRE assertion
	REQUIRE(${1:false});
# vim:ft=snippets
